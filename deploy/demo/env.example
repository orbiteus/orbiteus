# Copy to repo root as `.env.demo` and fill secrets before `docker compose -f docker-compose.demo.yml`.

POSTGRES_PASSWORD=generate-a-long-random-string
SECRET_KEY=openssl-rand-hex-32-here
BOOTSTRAP_ADMIN_EMAIL=admin@demo.orbiteus.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password

# Optional: host port for Next (nginx proxies here). Default 13100.
# DEMO_HOST_PORT=13100

# Optional JSON list for browser-origin API calls (same-origin demo usually does not need this).
# CORS_ORIGINS=["https://demo.orbiteus.com"]

<views>

  <!-- Customer list view -->
  <view name="crm.customer.list" model="crm.customer" type="list" priority="16">
    <list>
      <field name="name" string="Name"/>
      <field name="email" string="Email"/>
      <field name="phone" string="Phone"/>
      <field name="city" string="City"/>
      <field name="status" string="Status" widget="badge"/>
    </list>
  </view>

  <!-- Customer form view -->
  <view name="crm.customer.form" model="crm.customer" type="form" priority="16">
    <form>
      <header>
        <field name="status" widget="statusbar" statusbar_visible="lead,qualified,customer,inactive"/>
      </header>
      <sheet>
        <group string="Contact Information">
          <field name="name" required="1"/>
          <field name="email"/>
          <field name="phone"/>
          <field name="mobile"/>
          <field name="website"/>
        </group>
        <group string="Address">
          <field name="street"/>
          <field name="city"/>
          <field name="zip_code"/>
          <field name="country_code"/>
        </group>
        <group string="Classification">
          <field name="industry"/>
          <field name="company_size"/>
          <field name="source"/>
          <field name="assigned_user_id"/>
        </group>
      </sheet>
    </form>
  </view>

  <!-- Customer search view -->
  <view name="crm.customer.search" model="crm.customer" type="search" priority="16">
    <search>
      <field name="name" string="Name"/>
      <field name="email" string="Email"/>
      <field name="city" string="City"/>
      <filter name="active_customers" string="Customers" domain="[('status', '=', 'customer')]"/>
      <filter name="leads" string="Leads" domain="[('status', '=', 'lead')]"/>
      <group expand="0" string="Group By">
        <filter name="by_status" string="Status" context="{'group_by': 'status'}"/>
        <filter name="by_assigned" string="Assigned To" context="{'group_by': 'assigned_user_id'}"/>
      </group>
    </search>
  </view>

</views>
